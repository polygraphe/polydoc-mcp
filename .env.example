# Polydoc MCP Server Environment Configuration
# 
# IMPORTANT: If NODE_ENV is not set, the server defaults to PRODUCTION mode
# for security and performance reasons.

# Application Environment
# Values: development, production, test
# Default: production (if not set or invalid)
NODE_ENV=production

# Logging Configuration
# Values: debug, info, warn, error
POLYDOC_LOG_LEVEL=info

# File Processing Limits
# Maximum file size in bytes (default: 10MB)
POLYDOC_MAX_FILE_SIZE=10485760

# Maximum number of files to scan per request (default: 1000)
POLYDOC_MAX_FILES_PER_SCAN=1000

# Feature Toggles
# Enable detailed error messages in responses (default: true in dev, false in prod)
POLYDOC_ENABLE_DETAILED_ERRORS=false

# Enable metrics collection (default: true)
POLYDOC_ENABLE_METRICS=true

# Enable caching (default: false in dev, true in prod)
POLYDOC_CACHE_ENABLED=true

# Server Configuration
# Custom server name (optional)
POLYDOC_SERVER_NAME=polydoc-database-docs

# Operation timeout in milliseconds (default: 30000)
POLYDOC_TIMEOUT=30000

# Production Recommended Settings
# NODE_ENV=production
# POLYDOC_LOG_LEVEL=info
# POLYDOC_ENABLE_DETAILED_ERRORS=false
# POLYDOC_ENABLE_METRICS=true
# POLYDOC_CACHE_ENABLED=true
# POLYDOC_MAX_FILES_PER_SCAN=500

# Development Settings
# NODE_ENV=development
# POLYDOC_LOG_LEVEL=debug
# POLYDOC_ENABLE_DETAILED_ERRORS=true
# POLYDOC_ENABLE_METRICS=true
# POLYDOC_CACHE_ENABLED=false
