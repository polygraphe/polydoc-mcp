{
  "name": "polydoc-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for generating database documentation from codebase",
  "type": "module",
  "main": "build/polydoc.js",
  "bin": {
    "polydoc-mcp-server": "build/polydoc.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/polydoc.js",
    "start:stdio": "node build/polydoc-stdio.js",
    "dev": "tsc --watch",
    "dev:run": "tsx watch src/polydoc.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.1.0",
    "glob": "^10.3.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "database",
    "documentation",
    "codebase"
  ],
  "author": "Your Name",
  "license": "MIT"
}
